# ══════════════════════════════════════════════════════════════════════════════
# Ruya Backend — Environment Variables Template
# ══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your actual keys.
# NEVER commit .env to Git!

# ── AI Providers ─────────────────────────────────────────────────────────────
AI_PROVIDER=hybrid  # Options: 'groq', 'gemini', 'hybrid'

# Groq (Llama 3 - High Speed)
GROQ_API_KEY=gsk_your_groq_key_here

# Google (Gemini - Complex Reasoning)
GOOGLE_API_KEY=your_google_api_key_here

# ── TTS & Media ──────────────────────────────────────────────────────────────
ELEVENLABS_API_KEY=sk_your_elevenlabs_key_here
HF_API_TOKEN=hf_your_huggingface_token_here

# ── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_service_role_key_here

# ── Auth (optional — if unset, API is open for local dev) ────────────────────
# API_KEY=your_secret_api_key_here

# ── CORS (JSON array of allowed origins) ─────────────────────────────────────
CORS_ORIGINS=["http://localhost:5173"]

# ── Legacy (unused) ──────────────────────────────────────────────────────────
# OPENAI_API_KEY=
# OPENAI_MODEL=
